[core]
	editor = nvim
	pager = delta

# Machine-specific config (user identity, credential helpers, etc.)
# Keep account-specific GitHub identities out of the shared dotfiles repo.
[include]
	path = ~/.gitconfig.local
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	syntax-theme = Catppuccin Mocha
	dark = true
	hyperlinks = true
[diff]
	algorithm = histogram
[merge]
	conflictstyle = zdiff3
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[rerere]
	enabled = true
[alias]
	st = status
	co = checkout
	br = branch
	cm = commit -m
	d = diff
	ds = diff --staged
	lg = log --oneline --graph --decorate --all -20
